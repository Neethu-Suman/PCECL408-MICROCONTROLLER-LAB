OBJECTIVE
•	To interface a multi-digit 7-segment display (via an I2C-based driver) with the LPC2148 microcontroller and implement a synchronized counter that displays digits 0–9.

ALGORITHM
1.	I2C Configuration:
    o	Configure pins P0.2 (SDA0) and P0.3 (SCL0) using PINSEL0.
    o	Set the I2C clock frequency (e.g., 100 kHz) using I2CSCLH and I2CSCLL.
    o	Enable the I2C interface.
2.	I2C Write Protocol:
    o	Generate a START condition.
    o	Transmit the Slave Address of the 7-segment driver.
    o	Transmit the Data byte (hex code for the specific digit).
    o	Generate a STOP condition.
3.	Data Preparation: Store the 7-segment hex codes for digits 0–9 (0x3F for '0', 0x06 for '1', etc.) in an array.
4.	Display Logic: * Initialize the display by writing 0x00 (blank) to all digit addresses.
    o	In a continuous loop, iterate through the hex code array.
    o	Write the same digit value to all six digit addresses (0x70 to 0x7A) to show a synchronized count.
    o	Apply a delay of approximately 1 second between increments.

CODE

#include <nxp\iolpc2148.h>
#define counter_delay 0x4ffff // Counter Delay ( 1 second approx. )
void delay(unsigned int k)
{ 
  for(int i=0;i<k;i++); 
}
void i2c_config(void)
{
    PINSEL0|=0X00000050;      // To select the Port pins p0.2 and p0.3 as i2c configurable  ( P0.2 → SDA0,  P0.3 → SCL0)
    I2C0CONCLR=0X6C;          // To clear all bits in the i2c0 register
    I2C0CONSET=0X40;          // Bit 6 (I2EN) = 1 → Enables I2C module
    I2C0SCLH=70; 		      //Sets SCL high and low time 
    I2C0SCLL=50;              // To set clock rate as 100 KHZ 
}
void i2c_write(char address,char data)
{
    I2C0CONSET=0X20; 	        //sets the STA (Start) bit in the I2C control register, causing the LPC2148 to 
                                //generate a START condition on the I2C bus to begin communication.
    delay(50);
    while(I2C0STAT!=0x08);     //Wait stil Start condition transmitted
    I2C0CONCLR=0X28;           //clears the STA (Start) bit and SI (Interrupt) flag bit in the I2C control register 
                               //after a start condition has been transmitted, allowing the next stage of I2C communication to proceed.
    
    // To send a slave address
    
    I2C0DAT=address;
    delay(50);
    while(I2C0STAT!=0x18);     //wait until the slave address is successfully transmitted and acknowledged.
    I2C0CONCLR=0x08; 	       //clear the SI (Interrupt) flag bit of the I2C control register.
    I2C0DAT=data;	           //Data has been written to appropriate address
    delay(50);
    while(I2C0STAT!=0x28);      //Data transmitted, ACK received
    I2C0CONSET=0X10;            //sets the STO bit to generate a STOP condition, terminating I2C communication
    I2C0CONCLR=0x08;            //clears the SI (interrupt) flag to complete the current I2C operation and prepare for the next one.
    delay(50);
}
void counter()
{
  unsigned char data[10]={0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F};
  unsigned char s=0;
  int cnt;
    for(s=0;s<10;s++)   // loop to run the counter
  {
    
    i2c_write(0x70,data[s]);   // writing data to 1st digit (LSB)
    i2c_write(0x72,data[s]);   // writing data to 2nd digit 
    i2c_write(0x74,data[s]);   // writing data to 3rd digit 
    i2c_write(0x76,data[s]);   // writing data to 4th digit (MSB)
    i2c_write(0x78,data[s]); 
    i2c_write(0x7A,data[s]); 
    delay(counter_delay); // Counter Delay ( 1 second approx. )
      }   
  

}

{
  unsigned char i,address[6]={0x70,0x72, 0x74, 0x76, 0x78, 0x7A};
  i2c_config(); // confugring I2C for 7 segment driver .
  for(i=0;i<6;i++) {i2c_write(address[i],0x00);} // making all 7 segment blank. 
  while(1)
  {
  counter(); 
